{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: clang++ build active file",
            "command": "mkdir -p '${workspaceFolder}/build' && /usr/bin/clang++ -std=c++26 -g -O0 -Wall -Wextra -Wpedantic -fcolor-diagnostics -fansi-escape-codes '${file}' -o '${workspaceFolder}/build/${fileBasenameNoExtension}'",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Debug build → build/ : C++26, no optimization, full warnings."
        },
        {
            "type": "shell",
            "label": "C/C++: clang++ build active file (release)",
            "command": "mkdir -p '${workspaceFolder}/build' && /usr/bin/clang++ -std=c++26 -O3 -DNDEBUG -march=native -Wall -Wextra -fcolor-diagnostics -fansi-escape-codes '${file}' -o '${workspaceFolder}/build/${fileBasenameNoExtension}'",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Release build → build/ : C++26, -O3 -march=native for HFT hot paths."
        }
    ]
}
